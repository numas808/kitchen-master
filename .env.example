# Vercel / local development environment variables

# Frontend (Supabase)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Server-side Supabase (Vercel Functions でのみ使用)
# このキーは絶対にクライアント側に公開しないでください。
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App access protection
# 未設定ならパスワード保護は無効です。
APP_ACCESS_PASSWORD=your-access-password

# バックエンド検索プロバイダ
# cookpad: Cookpad のみを対象にスクレイピング（APIキー不要・推奨）
# tavily:  Tavily Search API を使用
# google:  Google Custom Search API を使用
SEARCH_PROVIDER=cookpad

# Tavily
# https://tavily.com で API Key を取得
TAVILY_API_KEY=tvly-your-tavily-api-key
# Tavily 検索対象ドメイン（カンマ区切り）
# 例: cookpad.com,delishkitchen.tv
TAVILY_INCLUDE_DOMAINS=cookpad.com

# 旧Google CSE互換（既存利用者向け）
# SEARCH_PROVIDER=google のときのみ使用
GOOGLE_SEARCH_API_KEY=your_google_search_api_key_here
GOOGLE_SEARCH_CX=your_search_engine_cx_here

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4.1-mini

# Optional port override for local API server
API_PORT=8787
